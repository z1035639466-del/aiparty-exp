  "props_required": [],
  "flow": [
    "阶段0 开局：每人领 MBTI 身份牌贴额头；公共看板亮出玩法说明；转盘配置三扇区。",
    "阶段1(循环5轮，每轮限时60秒)：转命运转盘 → 定当值人与赛道 → 按赛道执行对应规则 → 记分板即时结算 → 同时抽一张八卦纸条按座位往下传一位（每人只看得到上一棒写的内容）。",
    "阶段2 八卦终局：五轮跑完，八卦纸条正好传完一圈，公开对比首尾内容，全场用匿名投票器投\"最失真奖\"。",
    "阶段3 身份揭晓：全员摘下额头牌，公开核对整局猜没猜中过自己的标签。",
    "阶段4 总结算：记分板出总分，最高分获胜；垫底者领一个健身氛围的轻量惩罚（可跳过换成鼓掌陪跑）。"
  ],
  "rules": [
    {
      "flavor_name":"黑话植入",
      "mechanic":"声明质疑",
      "plain_rule":"密语卡上写了一个黑话词，当值人要在本轮聊天里自然说出这个词。时间到，当值人自己声明\"我说了/没说\"，别人可以当场质疑；质疑后翻密语卡核对真假，说谎的人受罚，冤枉别人的人也受罚。",
      "visibility":"自己看",
      "params": {"claim_prompt":"我这轮已经把密语卡上的黑话词自然说出来了吗？","challengers":"others","challenge_window_s":20,"verify_source":"prop_reveal:密语卡","verify_reveals":"prop_state","on_liar":{"scoring_ref":["黑话造假受罚","识破黑话加分"]},"on_false_accuse":{"scoring_ref":["黑话冤枉受罚","黑话被冤枉补偿"]}}
    },
    {
      "flavor_name":"直拍挑战",
      "mechanic":"判定",
      "plain_rule":"抽签筒抽出一个挑战名，全场看着当值人在限时内完成，时间到大家一键表决\"算不算过\"，过了加分，没过扣分。",
      "visibility":"全场公开",
      "params": {"source":"consensus","question":"这轮挑战算完成了吗？","verdict_options":["过","不过"],"on":{"过":{"scoring_ref":"挑战成功"},"不过":{"scoring_ref":"挑战失败"}}}
    },
    {
      "flavor_name":"挑战倒计时",
