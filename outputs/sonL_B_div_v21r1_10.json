      "visibility":"全场公开",
      "params": {"source":"consensus","question":"当值人猜对自己的标签了吗？","verdict_options":["过","不过"],"on":{"过":{"scoring_ref":"标签猜中加分"},"不过":{"scoring_ref":[]}}}
    },
    {
      "flavor_name":"命运抽人",
      "mechanic":"点名目标",
      "plain_rule":"每轮开始先转命运转盘，转出这一轮的赛道和当值人，当值人就是这轮要下场的人。",
      "visibility":"全场公开",
      "params": {"selector":"random","target_pool":"alive_others","on_named":{"scoring_ref":[]}}
    },
    {
