      "visibility":"自己看",
      "params": {"prompt":"这轮八卦谁传得最离谱？","input_kind":"options","options":"$派生:本轮传递链参与者","timeout_s":20,"reveal":"simultaneous","scoring_ref":["最失真奖加分"]}
