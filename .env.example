# 复制本文件为 .env,填上真实值——配一次永久生效,不必每开终端重 export。
# .env 已 gitignore,key 绝不进仓库。已在系统环境里的变量优先(export 可临时覆盖本文件)。

# —— 千问一家全包(推荐):一把 key 通文本/视觉/全模态 ——
DASHSCOPE_API_KEY=
# 百炼新账号是业务空间专属地址,控制台示例里的那个,填这里(留空用通用地址):
# DASHSCOPE_BASE_URL=https://<你的空间ID>.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# 或用 Anthropic / 其它国产口:
# ANTHROPIC_API_KEY=   MOONSHOT_API_KEY=   GLM_API_KEY=   MINIMAX_API_KEY=   DEEPSEEK_API_KEY=

# —— 听觉裁判(judge.audio · 语调打分"像不像")——
# 千问一家时这三个可全留空:有 DASHSCOPE_API_KEY 就自动用 qwen3.5-omni-plus。
# 只在用别家音频口时才填:
# AUDIO_JUDGE_BASE=   AUDIO_JUDGE_KEY=   AUDIO_JUDGE_MODEL=

# —— 演示资产出图(tools/render_demo_assets.py)——
IMAGE_API_BASE=https://api.openai.com/v1
IMAGE_API_KEY=
IMAGE_API_MODEL=gpt-image-2
